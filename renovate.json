{
  "$schema": "https://docs.renovatebot.com/renovate-json.schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update PlatformIO dependencies",
      "managerFilePatterns": [
        "/(^|/)platformio\\.ini$/"
      ],
      "matchStrings": [
        "[#;]\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+depName=(?<depName>[^\\s]+)\\n\\s*(?:[^@\\n]+?)\\s*@\\s*(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "github-tags",
        "github-releases"
      ],
      "pinDigests": true,
      "minimumReleaseAge": "14 days",
      "automerge": false,
      "groupName": "Monthly Dependencies",
      "schedule": [
        "before 5am on the first day of the month"
      ]
    }
  ]
}
