{
  "$schema": "https://docs.renovatebot.com/renovate-json.schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update PlatformIO dependencies",
      "fileMatch": [
        "(^|/)platformio\\.ini$"
      ],
      "matchStrings": [
        "[#;]\\s*renovate:\\s*datasource=(?<datasource>.*?)\\s+depName=(?<depName>.*?)\\n\\s*(?<packageName>[^@\\n]+?)\\s*@\\s*(?<currentValue>.*)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "github-tags",
        "github-releases"
      ],
      "pinDigests": true,
      "minimumReleaseAge": "14 days",
      "automerge": false,
      "groupName": "Monthly Dependencies",
      "schedule": [
        "before 5am on the first day of the month"
      ]
    }
  ]
}